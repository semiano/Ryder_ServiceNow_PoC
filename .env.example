# Example local environment variables
# Copy to .env and fill in secrets/tenant-specific values.
# Azure Functions local runtime reads local.settings.json by default.

# Core Function settings
AzureWebJobsStorage=UseDevelopmentStorage=true
FUNCTIONS_WORKER_RUNTIME=python

# ServiceNow
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com
SERVICENOW_AUTH_SCHEME=x-sn-apikey
SERVICENOW_API_TOKEN=replace-local-only

# Foundry
FOUNDRY_AGENT_ENDPOINT_URL=https://<resource>.services.ai.azure.com/api/projects/<project>/applications/<app>/protocols/openai/responses?api-version=2025-11-15-preview
FOUNDRY_TOKEN_SCOPE=https://ai.azure.com/.default
FOUNDRY_AGENT_PROMPT_PATH=system_documentation/foundry-agent-system-prompt.md

# Cosmos Table
COSMOS_TABLE_ENDPOINT=https://example.table.cosmos.azure.com:443/
COSMOS_TABLE_NAME=RcaReports
COSMOS_TABLE_CONNECTION_STRING=replace-local-only
COSMOS_TABLE_AUTH_MODE=aad
COSMOS_TABLE_ENSURE_EXISTS=false

# Graph (required for transcript lookup unless simulation is enabled)
GRAPH_TENANT_ID=replace-local-only
GRAPH_CLIENT_ID=replace-local-only
GRAPH_CLIENT_SECRET=replace-local-only
GRAPH_FALLBACK_USER_ID=

# Runtime behavior
LOG_LEVEL=INFO
TRANSCRIPT_LOOKBACK_DAYS=30
TRANSCRIPT_MAX_CHARS=120000
SIMULATE_CALL_TRANSCRIPT_LOOKUP=false
RCA_SCHEMA_VERSION=1.0
SERVICENOW_KB_ENABLED=false
SERVICENOW_KB_TABLE=kb_knowledge
ENABLE_LIVE_EXTERNALS=false
