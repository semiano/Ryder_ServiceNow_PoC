{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.40.2.10011",
      "templateHash": "10706951984796146347"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region for all resources"
      }
    },
    "appNamePrefix": {
      "type": "string",
      "minLength": 2,
      "metadata": {
        "description": "Application name prefix used for resource naming"
      }
    },
    "environmentName": {
      "type": "string",
      "allowedValues": [
        "dev",
        "prod"
      ],
      "metadata": {
        "description": "Deployment environment"
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Resource tags"
      }
    },
    "cosmosTableName": {
      "type": "string",
      "defaultValue": "RcaReports",
      "metadata": {
        "description": "Cosmos table name"
      }
    },
    "logLevel": {
      "type": "string",
      "defaultValue": "INFO",
      "metadata": {
        "description": "Log level for application"
      }
    },
    "transcriptLookbackDays": {
      "type": "int",
      "defaultValue": 30,
      "metadata": {
        "description": "Transcript lookback window in days"
      }
    },
    "transcriptMaxChars": {
      "type": "int",
      "defaultValue": 120000,
      "metadata": {
        "description": "Maximum transcript character count before truncation"
      }
    },
    "rcaSchemaVersion": {
      "type": "string",
      "defaultValue": "1.0",
      "metadata": {
        "description": "RCA schema version"
      }
    },
    "serviceNowKbEnabled": {
      "type": "string",
      "defaultValue": "false",
      "metadata": {
        "description": "ServiceNow KB placeholder enabled flag"
      }
    },
    "serviceNowKbTable": {
      "type": "string",
      "defaultValue": "kb_knowledge",
      "metadata": {
        "description": "ServiceNow KB table placeholder"
      }
    },
    "graphFallbackUserId": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional Graph fallback user id"
      }
    },
    "simulateCallTranscriptLookup": {
      "type": "string",
      "defaultValue": "false",
      "metadata": {
        "description": "Set true to bypass Graph transcript lookup and use simulated transcript file content"
      }
    },
    "foundryAccountName": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Optional Azure AI Foundry/Cognitive Services account name in this resource group for Function MI RBAC assignment"
      }
    },
    "serviceNowInstanceUrl": {
      "type": "string",
      "defaultValue": "https://your-instance.service-now.com",
      "metadata": {
        "description": "ServiceNow instance URL"
      }
    },
    "serviceNowAuthScheme": {
      "type": "string",
      "defaultValue": "x-sn-apikey",
      "metadata": {
        "description": "ServiceNow auth scheme (for API key use x-sn-apikey)"
      }
    },
    "foundryAgentEndpointUrl": {
      "type": "string",
      "defaultValue": "https://<resource>.services.ai.azure.com/api/projects/<project>/applications/<app>/protocols/openai/responses?api-version=2025-11-15-preview",
      "metadata": {
        "description": "Foundry Responses endpoint URL"
      }
    },
    "serviceNowApiToken": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "ServiceNow API token value to seed into Key Vault secret SERVICENOW-API-TOKEN"
      }
    }
  },
  "variables": {
    "baseName": "[toLower(format('{0}-{1}', parameters('appNamePrefix'), parameters('environmentName')))]",
    "storageName": "[toLower(format('st{0}', uniqueString(resourceGroup().id, parameters('appNamePrefix'), parameters('environmentName'))))]",
    "planName": "[format('{0}-plan', variables('baseName'))]",
    "functionName": "[format('{0}-func', variables('baseName'))]",
    "workspaceName": "[format('{0}-law', variables('baseName'))]",
    "appInsightsName": "[format('{0}-appi', variables('baseName'))]",
    "keyVaultName": "[toLower(take(replace(format('{0}-{1}-kv-{2}', parameters('appNamePrefix'), parameters('environmentName'), uniqueString(resourceGroup().id)), '-', ''), 24))]",
    "cosmosName": "[format('{0}-cosmos', variables('baseName'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[variables('storageName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "Standard_LRS"
      },
      "kind": "StorageV2",
      "properties": {
        "supportsHttpsTrafficOnly": true,
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false
      }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[variables('planName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "Y1",
        "tier": "Dynamic"
      },
      "kind": "functionapp",
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[variables('workspaceName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "sku": {
          "name": "PerGB2018"
        },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('appInsightsName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('workspaceName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults",
      "apiVersion": "2023-07-01",
      "name": "[variables('keyVaultName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "properties": {
        "tenantId": "[subscription().tenantId]",
        "sku": {
          "family": "A",
          "name": "standard"
        },
        "enableRbacAuthorization": true,
        "enabledForTemplateDeployment": true,
        "enablePurgeProtection": true,
        "softDeleteRetentionInDays": 7,
        "publicNetworkAccess": "Enabled"
      }
    },
    {
      "type": "Microsoft.DocumentDB/databaseAccounts",
      "apiVersion": "2024-08-15",
      "name": "[variables('cosmosName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "kind": "GlobalDocumentDB",
      "properties": {
        "databaseAccountOfferType": "Standard",
        "locations": [
          {
            "locationName": "[parameters('location')]",
            "failoverPriority": 0
          }
        ],
        "consistencyPolicy": {
          "defaultConsistencyLevel": "Session"
        },
        "capabilities": [
          {
            "name": "EnableTable"
          }
        ],
        "publicNetworkAccess": "Enabled",
        "enableAutomaticFailover": false
      }
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('keyVaultName'), 'SERVICENOW-API-TOKEN')]",
      "properties": {
        "value": "[parameters('serviceNowApiToken')]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('keyVaultName'), 'GRAPH-TENANT-ID')]",
      "properties": {
        "value": "set-me"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('keyVaultName'), 'GRAPH-CLIENT-ID')]",
      "properties": {
        "value": "set-me"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('keyVaultName'), 'GRAPH-CLIENT-SECRET')]",
      "properties": {
        "value": "set-me"
      },
      "dependsOn": [
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]"
      ]
    },
    {
      "type": "Microsoft.KeyVault/vaults/secrets",
      "apiVersion": "2023-07-01",
      "name": "[format('{0}/{1}', variables('keyVaultName'), 'COSMOS-TABLE-CONNECTION-STRING')]",
      "properties": {
        "value": "[listConnectionStrings(resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosName')), '2024-08-15').connectionStrings[0].connectionString]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosName'))]",
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[variables('functionName')]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "kind": "functionapp,linux",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "httpsOnly": true,
        "keyVaultReferenceIdentity": "SystemAssigned",
        "siteConfig": {
          "minTlsVersion": "1.2",
          "linuxFxVersion": "Python|3.12",
          "ftpsState": "Disabled",
          "appSettings": [
            {
              "name": "FUNCTIONS_EXTENSION_VERSION",
              "value": "~4"
            },
            {
              "name": "FUNCTIONS_WORKER_RUNTIME",
              "value": "python"
            },
            {
              "name": "AzureWebJobsStorage",
              "value": "[format('DefaultEndpointsProtocol=https;AccountName={0};EndpointSuffix=core.windows.net;AccountKey={1}', variables('storageName'), listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageName')), '2023-05-01').keys[0].value)]"
            },
            {
              "name": "APPLICATIONINSIGHTS_CONNECTION_STRING",
              "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').ConnectionString]"
            },
            {
              "name": "SERVICENOW_INSTANCE_URL",
              "value": "[parameters('serviceNowInstanceUrl')]"
            },
            {
              "name": "SERVICENOW_AUTH_SCHEME",
              "value": "[parameters('serviceNowAuthScheme')]"
            },
            {
              "name": "FOUNDRY_AGENT_ENDPOINT_URL",
              "value": "[parameters('foundryAgentEndpointUrl')]"
            },
            {
              "name": "COSMOS_TABLE_ENDPOINT",
              "value": "[reference(resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosName')), '2024-08-15').documentEndpoint]"
            },
            {
              "name": "COSMOS_TABLE_NAME",
              "value": "[parameters('cosmosTableName')]"
            },
            {
              "name": "LOG_LEVEL",
              "value": "[parameters('logLevel')]"
            },
            {
              "name": "TRANSCRIPT_LOOKBACK_DAYS",
              "value": "[string(parameters('transcriptLookbackDays'))]"
            },
            {
              "name": "TRANSCRIPT_MAX_CHARS",
              "value": "[string(parameters('transcriptMaxChars'))]"
            },
            {
              "name": "SIMULATE_CALL_TRANSCRIPT_LOOKUP",
              "value": "[parameters('simulateCallTranscriptLookup')]"
            },
            {
              "name": "RCA_SCHEMA_VERSION",
              "value": "[parameters('rcaSchemaVersion')]"
            },
            {
              "name": "SERVICENOW_KB_ENABLED",
              "value": "[parameters('serviceNowKbEnabled')]"
            },
            {
              "name": "SERVICENOW_KB_TABLE",
              "value": "[parameters('serviceNowKbTable')]"
            },
            {
              "name": "GRAPH_FALLBACK_USER_ID",
              "value": "[parameters('graphFallbackUserId')]"
            },
            {
              "name": "SERVICENOW_API_TOKEN",
              "value": "[format('@Microsoft.KeyVault(SecretUri={0}secrets/SERVICENOW-API-TOKEN/)', reference(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), '2023-07-01').vaultUri)]"
            },
            {
              "name": "GRAPH_TENANT_ID",
              "value": "[format('@Microsoft.KeyVault(SecretUri={0}secrets/GRAPH-TENANT-ID/)', reference(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), '2023-07-01').vaultUri)]"
            },
            {
              "name": "GRAPH_CLIENT_ID",
              "value": "[format('@Microsoft.KeyVault(SecretUri={0}secrets/GRAPH-CLIENT-ID/)', reference(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), '2023-07-01').vaultUri)]"
            },
            {
              "name": "GRAPH_CLIENT_SECRET",
              "value": "[format('@Microsoft.KeyVault(SecretUri={0}secrets/GRAPH-CLIENT-SECRET/)', reference(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), '2023-07-01').vaultUri)]"
            },
            {
              "name": "COSMOS_TABLE_CONNECTION_STRING",
              "value": "[format('@Microsoft.KeyVault(SecretUri={0}secrets/COSMOS-TABLE-CONNECTION-STRING/)', reference(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), '2023-07-01').vaultUri)]"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Insights/components', variables('appInsightsName'))]",
        "[resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosName'))]",
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]",
        "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('keyVaultName'), 'COSMOS-TABLE-CONNECTION-STRING')]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('keyVaultName'), 'GRAPH-CLIENT-ID')]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('keyVaultName'), 'GRAPH-CLIENT-SECRET')]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('keyVaultName'), 'GRAPH-TENANT-ID')]",
        "[resourceId('Microsoft.KeyVault/vaults/secrets', variables('keyVaultName'), 'SERVICENOW-API-TOKEN')]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]"
      ]
    },
    {
      "condition": "[not(empty(parameters('foundryAccountName')))]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.CognitiveServices/accounts', parameters('foundryAccountName'))]",
      "name": "[guid(resourceId('Microsoft.CognitiveServices/accounts', parameters('foundryAccountName')), variables('functionName'), 'foundry-cognitive-user')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'a97b65f3-24c7-4388-baec-2e87135dc908')]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('functionName')), '2023-12-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('functionName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]",
      "name": "[guid(resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName')), variables('functionName'), 'kv-secrets-user')]",
      "properties": {
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '4633458b-17de-408a-b874-0445c86b69e6')]",
        "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('functionName')), '2023-12-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', variables('functionName'))]",
        "[resourceId('Microsoft.KeyVault/vaults', variables('keyVaultName'))]"
      ]
    }
  ],
  "outputs": {
    "functionDefaultHostname": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', variables('functionName')), '2023-12-01').defaultHostName]"
    },
    "keyVaultName": {
      "type": "string",
      "value": "[variables('keyVaultName')]"
    },
    "cosmosEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.DocumentDB/databaseAccounts', variables('cosmosName')), '2024-08-15').documentEndpoint]"
    },
    "appInsightsConnectionString": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/components', variables('appInsightsName')), '2020-02-02').ConnectionString]"
    }
  }
}